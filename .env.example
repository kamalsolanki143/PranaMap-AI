# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pranamap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pranamap

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAP_STYLE=https://tiles.example.com/style.json

# External APIs
NASA_FIRMS_API_KEY=your-nasa-firms-api-key
OPENWEATHER_API_KEY=your-openweather-api-key
SENTINEL_HUB_API_KEY=your-sentinel-hub-api-key

# ML
MODEL_PATH=./ml/models
SHAP_CACHE_DIR=./ml/shap_cache

# Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@pranamap.ai
SMTP_PASSWORD=change-me
